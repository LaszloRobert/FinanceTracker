{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=FinanceTracker;Username=postgres;Password=sa"
  },
  "Jwt": {
    "Secret": "this-is-a-development-secret-key-that-must-be-at-least-32-chars",
    "Issuer": "FinanceTracker",
    "Audience": "FinanceTracker",
    "ExpirationInMinutes": 60
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:8081" }
      }
    ]
  },
  "AllowedHosts": "*"
}
