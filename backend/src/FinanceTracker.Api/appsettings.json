{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=FinanceTracker;Username=postgres;Password=your-password"
  },
  "Jwt": {
    "Secret": "your-jwt-secret-must-be-at-least-32-characters-long",
    "Issuer": "FinanceTracker",
    "Audience": "FinanceTracker",
    "ExpirationInMinutes": 60
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Seq"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:8081" }
      }
    ]
  },
  "GoCardless": {
    "SecretId": "your-secret-id",
    "SecretKey": "your-secret-key"
  },
  "AllowedHosts": "*"
}
